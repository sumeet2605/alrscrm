APP_NAME="ALRSCRM API"
ENVIRONMENT=local
APP_DEBUG=false
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://alrscrm:alrscrm@db:5432/alrscrm
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=replace-with-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
STORAGE_PROVIDER=local
STORAGE_SIGNED_URL_EXPIRE_SECONDS=900
DO_SPACES_REGION=blr1
DO_SPACES_BUCKET=
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_ENDPOINT_URL=
DO_SPACES_CDN_URL=
DO_SPACES_PATH_PREFIX=alrscrm
SEED_SAMPLE_TENANT=false
BOOTSTRAP_ADMIN_EMAIL=admin@admin.com
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_FORCE_PASSWORD_RESET=false
SAMPLE_OWNER_PASSWORD=
SAMPLE_OWNER_FORCE_PASSWORD_RESET=false
